# Assay configuration — copy to .env and fill in. `.env` is gitignored; never commit it.

# --- Required for probing (Phase L) ---

# Private key of the DEDICATED probe wallet (0x-prefixed, 64 hex chars).
# Fresh wallet only — never reuse a wallet holding other funds. Keep balance <= $50 USDC.
# Funds: USDC on Base mainnet. No ETH needed (x402 uses EIP-3009; payer spends no gas).
PROBE_WALLET_KEY=0x...

# Anthropic API key for the T3 LLM judge (Claude Haiku). ~100 output tokens per judged probe.
ANTHROPIC_API_KEY=sk-ant-...

# --- Spending guard ---

# Max total USDC the prober may spend per local calendar day. Probing halts when reached.
# (Per-payment hard cap of $0.05 is separate and hardcoded in src/prober.ts.)
DAILY_BUDGET_USDC=5

# --- Serving (Phase H — leave defaults for Phase L) ---

# Gate GET /score/* behind x402 payment ($0.005). Requires RECEIVE_WALLET_ADDRESS when true.
PAYMENTS_ENABLED=false

# Address (not key) that receives x402 payments for /score. Separate wallet from the probe wallet.
RECEIVE_WALLET_ADDRESS=

# --- Optional overrides ---

# SQLite database path.
DB_PATH=data/assay.db

# HTTP port for the API/leaderboard server.
PORT=3402
